# --- 三服务再架构 (apps / services / packages) ---
# Node (web)
node_modules/
apps/web/dist/
# Python (agent) — 注: fastapi/pytest 走系统 site-packages, 此处忽略本地 venv 与缓存
__pycache__/
*.pyc
.pytest_cache/
.venv/
# r-analysis 本地语料产物 (RDS, 系统生成, 勿提交)
services/r-analysis/**/*.rds
services/r-analysis/**/*.meta.json
# 注: apps/web/src/api/schema.d.ts (契约生成) 与 pnpm-lock.yaml 需提交, 不忽略
.merge-snapshots/
services/agent/.venv/
# 零伪造闭环 demo 的产物 (runlog/corpus_hashes JSON, 每次跑脚本重新生成, 非源码)
services/agent/demo_artifacts/

