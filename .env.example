# BiblioCN optional environment variables.
# Copy to .env for Docker Compose. Do not commit real keys.

# MinerU OCR. Optional; offline demo works without it.
OCR_AUTHORIZATION_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4

# OpenAI-compatible LLM. Optional; FakeLLM fallback is used when empty.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Sciverse search/content API. Optional.
SCIVERSE_API_TOKEN=
SCIVERSE_BASE_URL=https://api.sciverse.space

# OpenAI-compatible image generation. Optional.
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024

# Docker Compose defaults.
CORS_ORIGINS=http://localhost:8080
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://bibliocn:bibliocn@postgres:5432/bibliocn
BIBLIOCN_CORPORA_DIR=/data/corpora
