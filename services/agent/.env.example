# Agent service environment example.
# Copy to services/agent/.env for local uvicorn/pytest runs. Do not commit real keys.

# Required user configuration
# None. Local development can start with the defaults below.

# Optional external service keys and endpoints
OCR_AUTHORIZATION_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Reject localhost, private IPs, and .local Base URLs by default; set to 1 only for intentional internal LLM/API endpoints.
BIBLIOCN_ALLOW_PRIVATE_API_BASE_URLS=
SCIVERSE_API_TOKEN=
SCIVERSE_BASE_URL=https://api.sciverse.space

# 多源检索补强 (app/sources/)。缺 key 的源在可用源清单显式标"未配置"，不静默跳过。
# CORE 需 Bearer key (即插即用一档)；其余免鉴权，填 mailto/email 仅进 polite pool / 满足 Unpaywall 要求。
CORE_API_KEY=
OPENALEX_MAILTO=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
# 多源统一超时/重试 + PDF 安全下载闸门 (§4.5)
MULTISOURCE_TIMEOUT=30
MULTISOURCE_MAX_RETRIES=2
MULTISOURCE_PER_SOURCE_LIMIT=50
MULTISOURCE_TOTAL_CAP=200
PDF_DOWNLOAD_MAX_BYTES=52428800
PDF_DOWNLOAD_TIMEOUT=60
PDF_RESOLVE_MAX_CANDIDATES=25
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024

# Agent runtime
R_ANALYSIS_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
DATABASE_URL=postgresql+asyncpg://bibliocn@localhost/bibliocn
TEST_DATABASE_URL=postgresql+asyncpg://bibliocn@localhost/bibliocn_test
BIBLIOCN_CORPORA_DIR=/tmp/bibliocn_corpora

# Tuning and limits
R_REQUEST_TIMEOUT=120
R_INGEST_TIMEOUT=300
R_HEALTH_TIMEOUT=5
MAX_UPLOAD_BYTES=52428800
REVIEW_RECORDS_LIMIT=40
SCIVERSE_TIMEOUT=60
SCIVERSE_CONTENT_CHUNK_CHARS=7000
SCIVERSE_CONTENT_MAX_CHARS=500000
